# ============================================================
# TASINABILIR KURULUM — her sunucuda ayni sekilde calisir
# ============================================================
#
# ZORUNLU (sadece 1 tane):
#   Railway  -> Variables -> Add Reference -> Postgres.DATABASE_URL
#   VPS/Docker -> asagidaki DATABASE_URL'yi doldurun
#
DATABASE_URL=

# Asagidakiler OTOMATIK uretilir, bos birakin:
SESSION_SECRET=
JWT_SECRET=

# Asagidakiler OTOMATIK ayarlanir, elle degistirmeyin:
# PORT=          (Railway/Docker verir)
# NODE_ENV=production
# BASE_PATH=/

# OPSIYONEL — Telegram (yoksa uygulama yine calisir):
# Not: Bu projede env isimleri bilerek ters (Replit uyumu):
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# OPSIYONEL — Puppeteer (bos birakin, Linux'ta otomatik bulunur):
# PUPPETEER_EXECUTABLE_PATH=
PUPPETEER_SKIP_DOWNLOAD=true
